# WARNING: do NOT commit this file with real values filled in.
# The TMDB token and JWT secret are credentials — anyone with repo access could use them.
# Fill in locally and keep your changes out of commits.
TMDB_API_KEY=
TMDB_API_TOKEN=
GOOGLE_CLIENT_ID=
JWT_SECRET=
